                <zone h='18250' id='12' name='Retention Curve' pane-specification-id='0' param='[federated.1yzdnw319ru5091buzgm01nzf498].[mn:Calculation_1299094975459328:ok]' type-v2='color' w='13333' x='86000' y='27375'>
                  <zone-style>
                    <format attr='border-color' value='#000000' />
                    <format attr='border-style' value='none' />
